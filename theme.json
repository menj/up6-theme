{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "palette": [
        { "slug": "up6-deep-blue",  "color": "#1B3C53", "name": "Deep Blue"  },
        { "slug": "up6-mid-blue",   "color": "#2E5871", "name": "Mid Blue"   },
        { "slug": "up6-accent-red", "color": "#C0392B", "name": "Accent Red" },
        { "slug": "up6-beige",      "color": "#C4B5A5", "name": "Beige"      },
        { "slug": "up6-white",      "color": "#ffffff", "name": "White"      },
        { "slug": "up6-off-white",  "color": "#f8f7f5", "name": "Off White"  }
      ],
      "custom": true,
      "customDuotone": false,
      "customGradient": false,
      "defaultPalette": true
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'DM Sans', sans-serif",
          "slug": "dm-sans",
          "name": "DM Sans"
        },
        {
          "fontFamily": "'Source Serif 4', Georgia, serif",
          "slug": "source-serif-4",
          "name": "Source Serif 4"
        }
      ],
      "defaultFontSizes": false
    },
    "layout": {
      "contentSize": "54rem",
      "wideSize": "1200px"
    },
    "spacing": {
      "units": ["px", "em", "rem", "%", "vw"]
    }
  },
  "styles": {
    "color": {
      "background": "#ffffff",
      "text": "#1B3C53"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--source-serif-4)",
      "fontSize": "1rem",
      "lineHeight": "1.75"
    },
    "elements": {
      "h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--dm-sans)", "fontWeight": "900" } },
      "h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--dm-sans)", "fontWeight": "900" } },
      "h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--dm-sans)", "fontWeight": "700" } },
      "h4": { "typography": { "fontFamily": "var(--wp--preset--font-family--dm-sans)", "fontWeight": "700" } },
      "link": {
        "color": { "text": "#1B3C53" },
        "typography": { "textDecoration": "none" },
        ":hover": { "color": { "text": "#C0392B" } }
      }
    }
  }
}
